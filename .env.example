# ============================================================
# 🚀 ENVIRONMENT VARIABLES — Template Vibe Coding
# ============================================================
# Copy file ini ke .env.local dan isi nilai-nilainya.
# cp .env.example .env.local
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Template Vibe Coding"

# --- Database (jika pakai) ---
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# --- Supabase (wajib untuk auth) ---
# Dapatkan dari https://supabase.com dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Supabase Admin (wajib untuk kelola user) ---
# Dapatkan dari Supabase dashboard -> Project Settings -> API -> service_role key
# HANYA untuk server-side, JANGAN bocor ke client!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Authentication (opsional, untuk OAuth) ---
# AUTH_SECRET="your-secret-here"
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# --- Storage (jika pakai upload) ---
# STORAGE_BUCKET=
# STORAGE_REGION=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# --- API Keys (jika pakai layanan eksternal) ---
# OPENAI_API_KEY=
# RESEND_API_KEY=